# Force LF line endings on every checkout. biome.json sets
# `formatter.lineEnding = "lf"`; without this, a Windows clone with the
# default `core.autocrlf=true` would land CRLF in the working tree and
# every file would fail biome's format check on `npm run lint`.
* text=auto eol=lf

# Binary file types — never touched by EOL normalization.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.sqlite3 binary
